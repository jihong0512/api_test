# ============================================
# APITest Backend 环境变量配置示例
# ============================================
# 复制此文件为 .env 并根据实际情况修改配置
# cp .env.example .env

# ============================================
# 应用基础配置
# ============================================
APP_NAME=API接口智能测试系统
DEBUG=true

# ============================================
# MySQL数据库配置
# ============================================
# 本地开发模式：端口3309（Docker映射端口）
# Docker模式：端口3306（容器内部端口）
MYSQL_HOST=localhost
MYSQL_PORT=3309
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=api_test

# ============================================
# Redis缓存配置
# ============================================
# 本地开发模式：端口6382（Docker映射端口）
# Docker模式：端口6379（容器内部端口）
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=

# ============================================
# Neo4j图数据库配置
# ============================================
# Bolt端口：7687（本地和Docker都使用此端口）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=123456789

# ============================================
# MinIO对象存储配置
# ============================================
# 本地开发模式：localhost:9005（Docker映射端口）
# Docker模式：minio:9000（容器内部地址）
MINIO_ENDPOINT=localhost:9005
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123456
MINIO_BUCKET=api-test

# ============================================
# ChromaDB向量数据库配置
# ============================================
CHROMA_PERSIST_DIR=./chroma_db

# ============================================
# 大模型API配置（必须配置）
# ============================================

# DeepSeek API配置（用于测试用例生成和脚本生成）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 阿里云DashScope配置 - Qwen模型（用于文档解析、视觉分析等）
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-plus

# 嵌入模型配置（使用通义千问API）
EMBEDDING_MODEL=text-embedding-v3

# 重排序模型配置
RERANKER_MODEL=qwen3-rerank

# ============================================
# JWT安全配置
# ============================================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# 文件上传配置
# ============================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=104857600

# ============================================
# 配置说明
# ============================================
# 1. 所有配置项都可以从 .env 文件读取，会覆盖代码中的默认值
# 2. API密钥（DEEPSEEK_API_KEY、QWEN_API_KEY）必须配置，否则相关功能无法使用
# 3. 本地开发模式：基础服务运行在Docker中，端口映射到本地
# 4. Docker模式：所有服务运行在Docker容器中，使用容器内部网络地址
# 5. 生产环境：请修改SECRET_KEY为强随机字符串
