# ============================================
# APITest Backend 环境变量配置
# ============================================
# 所有配置项都可以通过此文件覆盖代码中的默认值
# 参考: uitest/backend/.env

# ============================================
# 应用基础配置
# ============================================
APP_NAME=API接口智能测试系统
DEBUG=true

# ============================================
# MySQL数据库配置
# ============================================
# 本地开发模式：端口3309（Docker映射端口）
# Docker模式：端口3306（容器内部端口，使用mysql作为host）
MYSQL_HOST=localhost
MYSQL_PORT=3309
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=api_test

# ============================================
# Redis缓存配置
# ============================================
# 本地开发模式：端口6382（Docker映射端口）
# Docker模式：端口6379（容器内部端口，使用redis作为host）
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=

# ============================================
# Neo4j图数据库配置
# ============================================
# Bolt端口：7687（本地和Docker都使用此端口）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=123456789

# ============================================
# MinIO对象存储配置
# ============================================
# 本地开发模式：localhost:9005（Docker映射端口）
# Docker模式：minio:9000（容器内部地址）
MINIO_ENDPOINT=localhost:9005
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123456
MINIO_BUCKET=api-test

# ============================================
# ChromaDB向量数据库配置
# ============================================
CHROMA_PERSIST_DIR=./chroma_db

# ============================================
# 大模型API配置（必须配置）
# ============================================

# DeepSeek API配置（用于测试用例生成和脚本生成）
DEEPSEEK_API_KEY=sk-abebebd1bc2b404fa0556d46912a379e
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 阿里云DashScope配置 - Qwen模型（用于文档解析、视觉分析等）
QWEN_API_KEY=sk-5233a3a4b1a24426b6846a432794bbe2
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-plus

# 嵌入模型配置（使用通义千问API）
EMBEDDING_MODEL=text-embedding-v3

# 重排序模型配置
RERANKER_MODEL=qwen3-rerank

# ============================================
# JWT安全配置
# ============================================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# 文件上传配置
# ============================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=104857600
